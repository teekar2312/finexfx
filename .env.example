# FinexFX AI Trading System — Environment Variables (REAL TRADING)
# Copy this file to `.env` and adjust values for your environment.

# Drizzle ORM database URL (SQLite by default — absolute path recommended)
# Format: `file:/absolute/path/to/db.sqlite` (the `file:` prefix is optional)
DATABASE_URL=file:./db/custom.db

# ─── MT5 Bridge Configuration (REQUIRED for real trading) ───
# The mt5-bridge mini-service connects to a Python bridge running on a
# Windows machine with MetaTrader 5 installed. See:
#   mini-services/mt5-bridge/README.md
# for deployment instructions.

# URL of the Python MT5 bridge (mt5_bridge.py running on the Windows MT5 machine)
MT5_PYTHON_BRIDGE_URL=http://192.168.1.100:5050

# URL of the mt5-bridge Node service (runs locally on port 3050)
MT5_BRIDGE_URL=http://localhost:3050

# ─── NextAuth Configuration (REQUIRED) ───
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-a-random-secret
NEXTAUTH_URL=http://localhost:3000

# ─── Service API Key (REQUIRED for background services) ───
# Shared secret for SL/TP monitor + heartbeat-monitor + other background
# services to authenticate with protected API routes.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must match the SERVICE_API_KEY set in each mini-service's environment.
SERVICE_API_KEY=change-me-to-a-service-key

# ─── Bridge Authentication (REQUIRED for production security) ───
# Shared secret between Python bridge and Node.js bridge.
# ⚠️  In production (NODE_ENV=production), the system logs an ERROR on
#     startup if this is not set. All bridge requests include this as an
#     Authorization header. The mt5-bridge mini-service must validate it.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BRIDGE_API_KEY=

# Token for Price-Feed WebSocket authentication.
# If not set, WebSocket is unsecured (anyone can connect).
PRICE_FEED_TOKEN=

# ─── Price-Feed WebSocket URL (for local Windows dev without Caddy) ───
# On cloud/sandbox: leave unset (uses Caddy gateway ?XTransformPort=3003)
# On local Windows: set to http://localhost:3003 (direct connection, no Caddy)
NEXT_PUBLIC_PRICE_FEED_URL=http://localhost:3003

# ─── LLM Provider Configuration (RECOMMENDED — replaces z-ai-web-dev-sdk) ───
# The AI analysis, news synthesis, and calendar synthesis features use a
# configurable LLM provider. Default: ollama (local, free, no internet needed).
#
# Supported providers:
#   ollama  — Local LLM via Ollama (default). Install: https://ollama.com
#   openai  — OpenAI API (gpt-4o-mini recommended for cost)
#   groq    — Groq API (free tier available, very fast)
#   z-ai    — Z.AI internal SDK (only works in Z.AI sandbox)
#
LLM_PROVIDER=ollama

# ─── Ollama Configuration (default provider) ───
# Install Ollama: https://ollama.com then run: ollama pull llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ─── OpenAI Configuration (alternative provider) ───
# Get your API key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# ─── Groq Configuration (alternative provider) ───
# Get your API key at: https://console.groq.com
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# ─── Z.AI SDK Configuration (LEGACY — only for Z.AI sandbox) ───
# If LLM_PROVIDER=z-ai, the system will look for a .z-ai-config file.
# This only works inside the Z.AI platform. For production on Windows,
# use ollama or openai instead.
# The .z-ai-config file should be placed in:
#   1. Project root
#   2. Home directory
#   3. /etc/.z-ai-config (Linux only)

# ─── Paper Trading Mode (optional — for strategy testing) ───
# Set to "true" to enable paper trading. Trades will be simulated
# locally (no MT5 execution) but use real price data from the bridge.
# Paper trades are tagged with source='paper' in the database.
# PAPER_TRADING=false

# ─── Heartbeat Monitor ───
# The heartbeat-monitor mini-service pings the MT5 bridge every 10 seconds.
# If the bridge is offline for > 30 seconds, it triggers emergency close
# of all open positions via /api/health/mt5-disconnect.
# HEARTBEAT_ENABLED=true

# ─── Daily Summary Schedule ───
# Cron expression for the daily P&L summary (default: every day at 22:00 UTC).
# Set to empty string to disable.
# DAILY_SUMMARY_CRON=0 22 * * *

# ─── News API Keys (optional — for real news feed) ───
# If unset, the dashboard uses LLM-synthesized news headlines.
# Get keys at:
#   FINNHUB_KEY: https://finnhub.io (free tier available)
#   MARKETAUX_KEY: https://marketaux.com (free tier available)
# FINNHUB_KEY=
# MARKETAUX_KEY=

# ─── Webhook URLs (optional — configure via Settings → Webhook instead) ───
# DISCORD_WEBHOOK_URL=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# SLACK_WEBHOOK_URL=